# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
# `.env` (no suffix) is committed and holds local-dev placeholders only —
# see AGENTS.md §3 / lib/integrations/index.ts. Real secrets go in
# `.env.local` (gitignored) per Next.js convention.
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Deploy artefacts (Azure App Service zip-deploy staging).
# `.deploy/` is the standalone-bundle staging dir, `deploy.zip` is the
# zip-deploy payload — both are ad-hoc outputs of the manual deploy flow
# documented in docs/deploy/azure.md. Never tracked.
/.deploy/
/deploy-pkg/
/deploy.zip

# Playwright
/test-results/
