// Prisma schema for the WDTS AI Program Console — v0.1 prototype
// See ../README.md and ../Dashboard_Scoping_v1.md §3.1 for context.
// v0.1 keeps a subset of the canonical schema; v0.2 will add ExceptionRequest,
// ReclamationEvent, BudgetSnapshot, FrictionBudgetMetric, etc.
//
// WORKAROUND (v0.1): pinned to prisma@^6 in package.json. Prisma 7 deprecated
// `datasource.url` inside schema.prisma in favour of `prisma.config.ts` with
// adapters. Revisit when migrating to v0.2 / production.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  displayName String
  managerId   String?
  manager     User?    @relation("UserManager", fields: [managerId], references: [id])
  reports     User[]   @relation("UserManager")
  roleTag     String
  region      String
  status      String   @default("ACTIVE") // HRIS-style: ACTIVE | LEFT | ON_LEAVE
  createdAt   DateTime @default(now())

  // Dashboard RBAC (LDR 0005) — distinct from `roleTag` (HRIS role like "ENG").
  // `dashboardRoleId` is the FK to Role; nullable so JIT-provisioning can
  // upsert without resolving the role first. The auth layer treats null as
  // "look up the USER built-in".
  dashboardRoleId String?
  dashboardRole   Role?   @relation(fields: [dashboardRoleId], references: [id])
  // `disabled` blocks sign-in. Distinct from HRIS `status=LEFT` (which is a
  // statement about the org), this is "you used to have access; you don't
  // any more". Owner cannot be disabled.
  disabled        Boolean @default(false)
  // Exactly one User row should have `isOwner=true` (enforced at the
  // application level — partial unique indexes need a manual migration on
  // PG and aren't worth the complexity for v0.3). Owner is always implicitly
  // ADMIN, can't be demoted by anyone, can't be disabled by anyone.
  isOwner         Boolean @default(false)
  // Optional org title for display ("Chief Technology Officer · Head of AI
  // Task Force"). Free-text, distinct from `roleTag`.
  title           String?

  licenses     License[]
  usageRecords UsageRecord[]
  decisions    Decision[]    @relation("DecisionSubject")
}

/// Dashboard authorization role. Built-in roles (USER / MANAGER / FINOPS /
/// ADMIN) are upserted from code on every seed run; custom roles are
/// admin-created. The `permissions` array is the only source of truth for
/// what a role grants — built-in role permission sets are re-synced from
/// `lib/rbac/built-in-roles.ts` on seed, custom roles are user-edited via
/// /settings/roles. See LDR 0005.
model Role {
  id           String   @id @default(uuid())
  /// Stable identifier. Built-ins use uppercase enum-style keys ("ADMIN",
  /// "FINOPS"); custom roles use admin-chosen kebab-case slugs ("auditor").
  key          String   @unique
  displayName  String
  description  String?
  /// Built-in roles are protected from delete and from key/permission edits.
  /// `displayName` and `description` are still editable for built-ins —
  /// e.g. "ADMIN" can be renamed to "Program Owner" without affecting the
  /// `key` that code references.
  isBuiltIn    Boolean  @default(false)
  /// Code-defined permission keys this role grants. Ordering not significant.
  /// See `lib/rbac/permissions.ts` for the full catalog.
  permissions  String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users        User[]
}

model License {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  product     String // CHATGPT | CODEX | CURSOR | CLAUDE_AI | M365_COPILOT
  subTier     String
  capUsdMonth Float?
  grantedAt   DateTime  @default(now())
  expiresAt   DateTime?
  source      String    @default("AUTO_PROVISIONED")
  flag        String? // optional marker e.g. "likely-reclaim"

  @@unique([userId, product])
  @@index([product, subTier])
}

model UsageRecord {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  product   String
  model     String
  tokensIn  Int?
  tokensOut Int?
  costUsd   Float?
  decision  String   @default("ALLOWED")
  region    String
  ts        DateTime

  @@index([userId, ts])
  @@index([product, ts])
}

model Decision {
  id            String   @id @default(uuid())
  type          String // TIER_PROMOTION | TIER_DEMOTION | RECLAMATION | EXCEPTION_GRANT | METHODOLOGY_CHANGE | CAP_ADJUSTMENT | CURSOR_SEAT_GRANT | CURSOR_SEAT_RECLAIM
  subjectUserId String?
  subject       User?    @relation("DecisionSubject", fields: [subjectUserId], references: [id])
  beforeState   String // JSON-as-string for v0.1 simplicity
  afterState    String
  actorEmail    String
  justification String
  evidenceLink  String?
  ts            DateTime @default(now())

  @@index([type, ts])
  @@index([ts])
}
