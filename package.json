{
  "name": "wdts-ai-program-console",
  "version": "0.2.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agoyalwdts/wdts-ai-program-console.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "smoke:usage-ingest": "tsx scripts/gateway-mirror/smoke-usage-ingest.ts",
    "smoke:litellm": "tsx scripts/gateway-mirror/smoke-litellm.ts",
    "ci": "npm run typecheck && npm run lint && npm test",
    "ship:check": "npx prisma generate && npm run ci && npm run build && CI=true npm run test:e2e",
    "db:test:setup": "tsx tests/setup-test-db.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:push": "prisma db push",
    "reconcile:azuread": "tsx prisma/scripts/reconcile-azuread.ts",
    "reconcile:azuread:dry": "tsx prisma/scripts/reconcile-azuread.ts --dry-run",
    "db:disable-non-allowlist": "tsx scripts/disable-users-not-on-allowlist.ts",
    "db:ack-cursor-global-region-alerts": "tsx scripts/ack-cursor-global-region-alerts.ts",
    "db:ack-vendor-global-region-alerts": "tsx scripts/ack-vendor-global-region-alerts.ts",
    "db:ack-cursor-default-model-alerts": "tsx scripts/ack-cursor-default-model-alerts.ts",
    "db:ack-cursor-allowlist-false-positives": "tsx scripts/ack-cursor-allowlist-false-positives.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "papaparse": "^5.5.3",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
