# Local-dev placeholders only. Real / live values go in `.env.local`
# (gitignored). This file is checked in so a freshly-cloned repo runs end-to-
# end against synthetic data without any extra setup. Do NOT put real
# secrets here.

# Postgres for the dev DB. The test DB is derived as `<dbname>_test` per
# tests/db-utils.ts.
DATABASE_URL="postgresql://wdts:wdts_dev@localhost:5432/wdts_ai_console?schema=public"

# --- v0.2 auth + identity (placeholders; real values in .env.local) ---
# AZURE_AD_TENANT_ID="<tenant-uuid>"
# AZURE_AD_CLIENT_ID="<app-registration-uuid>"
# AZURE_AD_CLIENT_SECRET="<client-secret>"
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="<openssl rand -base64 32>"

# --- v0.2 AAD security-group → dashboard-role mapping (Track 2) ---
# Comma-separated lists of AAD group object IDs (UUIDs). Empty / unset →
# the email-pattern fallback in lib/auth-roles.ts wins. See ADR 0001
# and the sandbox bridge note in lib/auth-roles.ts. The AAD app
# registration must also be configured to emit the `groups` claim
# (Token configuration → groupMembershipClaims=SecurityGroup).
# AZURE_AD_GROUP_ADMIN_IDS=""
# AZURE_AD_GROUP_FINOPS_IDS=""
# AZURE_AD_GROUP_MANAGER_IDS=""

# --- v0.2 integration mode flags (default = synthetic) ---
# Each client can be flipped to `real` once its credentials are in
# .env.local. See lib/integrations/index.ts.
# INTEGRATION_GATEWAY="synthetic"
# INTEGRATION_CURSOR="synthetic"
# INTEGRATION_OPENAI="synthetic"
# INTEGRATION_ANTHROPIC="synthetic"
# INTEGRATION_M365GRAPH="synthetic"
# INTEGRATION_AZUREAD="synthetic"
# INTEGRATION_DEEL="synthetic"
# INTEGRATION_POLICYREPO="synthetic"
# INTEGRATION_AZUREOPENAI="synthetic"

# --- Azure OpenAI (only used when INTEGRATION_AZUREOPENAI=real) ---
# AZURE_OPENAI_ENDPOINT="https://<resource>.openai.azure.com/"
# AZURE_OPENAI_API_KEY="<key>"
