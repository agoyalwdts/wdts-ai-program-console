# Local-dev placeholders only. Real / live values go in `.env.local`
# (gitignored). This file is checked in so a freshly-cloned repo runs end-to-
# end against synthetic data without any extra setup. Do NOT put real
# secrets here.

# Postgres for the dev DB. The test DB is derived as `<dbname>_test` per
# tests/db-utils.ts.
DATABASE_URL="postgresql://wdts:wdts_dev@localhost:5432/wdts_ai_console?schema=public"

# --- v0.2 auth + identity (placeholders; real values in .env.local) ---
# AZURE_AD_TENANT_ID="<tenant-uuid>"
# AZURE_AD_CLIENT_ID="<app-registration-uuid>"
# AZURE_AD_CLIENT_SECRET="<client-secret>"
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="<openssl rand -base64 32>"

# --- v0.2 AAD security-group → dashboard-role mapping (Track 2) ---
# Comma-separated lists of AAD group object IDs (UUIDs). Empty / unset →
# the email-pattern fallback in lib/auth-roles.ts wins. See ADR 0001
# and the sandbox bridge note in lib/auth-roles.ts. The AAD app
# registration must also be configured to emit the `groups` claim
# (Token configuration → groupMembershipClaims=SecurityGroup).
# AZURE_AD_GROUP_ADMIN_IDS=""
# AZURE_AD_GROUP_FINOPS_IDS=""
# AZURE_AD_GROUP_MANAGER_IDS=""

# --- v0.2 integration mode flags (default = synthetic) ---
# Each client can be flipped to `real` once its credentials are in
# .env.local. See lib/integrations/index.ts.
# INTEGRATION_GATEWAY="synthetic"
# INTEGRATION_CURSOR="synthetic"
# INTEGRATION_OPENAI="synthetic"
# INTEGRATION_ANTHROPIC="synthetic"
# INTEGRATION_M365GRAPH="synthetic"
# INTEGRATION_AZUREAD="synthetic"
# INTEGRATION_DEEL="synthetic"
# INTEGRATION_POLICYREPO="synthetic"
# INTEGRATION_AZUREOPENAI="synthetic"

# --- Azure OpenAI (only used when INTEGRATION_AZUREOPENAI=real) ---
# AZURE_OPENAI_ENDPOINT="https://<resource>.openai.azure.com/"
# AZURE_OPENAI_API_KEY="<key>"

# --- Deel HRIS (only used when INTEGRATION_DEEL=real) ---
# DEEL_API_TOKEN="<deel-api-token>"
# Webhook receiver at /api/webhooks/deel verifies HMAC-SHA256 against
# this secret. The route is HMAC-authed (not session-authed); ensure
# the secret is rotated independently of the API token above.
# DEEL_WEBHOOK_SECRET="<webhook-signing-secret>"

# --- Cursor (only used when INTEGRATION_CURSOR=real) ---
# WDTS Enterprise SCIM 2.0 base URL — exact path depends on the
# workspace's SCIM provisioning setup. Typically of the form
# https://cursor.com/api/scim/v2 (no trailing slash; the client strips
# one if present).
# CURSOR_SCIM_BASE_URL="https://cursor.com/api/scim/v2"
# CURSOR_ADMIN_TOKEN="<scim-bearer-token>"

# --- M365 Copilot reports (only used when INTEGRATION_M365GRAPH=real) ---
# The m365graph real client reuses AZURE_AD_TENANT_ID / _CLIENT_ID /
# _CLIENT_SECRET above. The app registration must additionally have
# admin consent for Reports.Read.All (and User.Read.All if not already).
# Override the SKU id list when WDTS adds Copilot variants:
# M365_COPILOT_SKU_IDS="639dec6b-bb19-468b-871c-c5c441c4b0cb"

# --- OpenAI Enterprise admin (only used when INTEGRATION_OPENAI=real) ---
# The admin API key is distinct from a regular OpenAI API key — generate
# it under organisation settings. Required scope: admin (read).
# OPENAI_ADMIN_API_KEY="sk-admin-..."
# OPENAI_ORG_ID="org-..."

# --- Anthropic admin (only used when INTEGRATION_ANTHROPIC=real) ---
# The admin key is also distinct from regular Claude API keys; under
# Console → Settings → Workspaces → Admin keys.
# ANTHROPIC_ADMIN_API_KEY="sk-ant-admin-..."
# ANTHROPIC_ORG_ID="..."
# ANTHROPIC_WORKSPACE_ID="..."

# --- Policy repo (only used when INTEGRATION_POLICYREPO=real) ---
# Fine-grained PAT scoped to the policy repo. Required scopes:
#   contents:write, pull_requests:write
# Branch protection on the policy repo is what stops the dashboard from
# merging its own PR — see scoping §4 + AGENTS.md §3.
# POLICYREPO_OWNER="<github-org-or-user>"
# POLICYREPO_NAME="codex-policies"
# POLICYREPO_TOKEN="<github-pat>"
# POLICYREPO_DEFAULT_BRANCH="main"
